<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ==================== 固定不动的元素 ==================== -->

    <!-- 背景 -->
    <ImageView
        android:id="@+id/iv_bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:elevation="0dp"
        android:translationY="40dp"
        android:scaleType="fitXY"
        android:src="@drawable/bg_chat"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ic_chat_hot -->
    <ImageView
        android:id="@+id/iv_chat_hot"
        android:layout_width="9dp"
        android:layout_height="707dp"
        android:layout_marginStart="19dp"
        android:layout_marginTop="100dp"
        android:elevation="4dp"
        android:scaleType="fitXY"
        android:src="@drawable/ic_chat_hot"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- HOT 文字 -->
    <TextView
        android:id="@+id/tv_hot_title"
        android:layout_width="30dp"
        android:layout_height="17dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="75dp"
        android:fontFamily="@font/inter_regular"
        android:gravity="center"
        android:text="HOT"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Check1 组件 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cv_check1"
        android:layout_width="55dp"
        android:layout_height="23dp"
        android:layout_marginStart="53dp"
        android:layout_marginTop="63dp"
        android:elevation="15dp"
        app:cardBackgroundColor="#000000"
        app:cardCornerRadius="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/ic_chat_check"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_chat_check" />

            <TextView
                android:id="@+id/all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:fontFamily="sans-serif-medium"
                android:text="all"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Check2 组件 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cv_check2"
        android:layout_width="55dp"
        android:layout_height="23dp"
        android:layout_marginStart="124dp"
        android:layout_marginTop="63dp"
        android:elevation="15dp"
        app:cardBackgroundColor="#D9D9D9"
        app:cardCornerRadius="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="idol"
                android:textColor="#000000"
                android:textSize="15sp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Check3 组件 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cv_check3"
        android:layout_width="55dp"
        android:layout_height="23dp"
        android:layout_marginStart="195dp"
        android:layout_marginTop="63dp"
        android:elevation="15dp"
        app:cardBackgroundColor="#D9D9D9"
        app:cardCornerRadius="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="music"
                android:textColor="#000000"
                android:textSize="15sp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Check4 组件 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cv_check4"
        android:layout_width="55dp"
        android:layout_height="23dp"
        android:layout_marginStart="266dp"
        android:layout_marginTop="63dp"
        android:elevation="15dp"
        app:cardBackgroundColor="#D9D9D9"
        app:cardCornerRadius="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="dance"
                android:textColor="#000000"
                android:textSize="15sp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Check5 组件 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cv_check5"
        android:layout_width="55dp"
        android:layout_height="23dp"
        android:layout_marginStart="337dp"
        android:layout_marginTop="63dp"
        android:elevation="15dp"
        app:cardBackgroundColor="#D9D9D9"
        app:cardCornerRadius="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="others"
                android:textColor="#000000"
                android:textSize="15sp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- ==================== 标签容器 ==================== -->
    <LinearLayout
        android:id="@+id/layout_tags_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/cv_check1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ==================== 可滚动的内容区域 ==================== -->

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="110dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_chat_list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        android:paddingTop="0dp"
        android:clipToPadding="false" />
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>



</androidx.constraintlayout.widget.ConstraintLayout>
