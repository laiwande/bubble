<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 背景图 - 延伸到屏幕底部，上方留出40dp白色间隙 -->
    <ImageView
        android:id="@+id/iv_bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="fitXY"
        android:src="@drawable/bg_square"
        android:layout_marginTop="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 顶部标题栏占位 -->
    <View
        android:id="@+id/top_placeholder"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 左上角菜单按钮 -->
    <ImageView
        android:id="@+id/iv_menu"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="25dp"
        android:layout_marginTop="56dp"
        android:src="@drawable/ic_square_menu"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Square 标题 - 居中 -->
    <TextView
        android:id="@+id/tv_square_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="56dp"
        android:text="Square"
        android:textColor="#000000"
        android:textSize="20sp"
        android:textStyle="bold"
        android:fontFamily="@font/inter"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 右上角头像（26x26）- 靠右对齐 -->
    <ImageView
        android:id="@+id/iv_avatar_top"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:layout_marginTop="58dp"
        android:layout_marginEnd="25dp"
        android:background="@drawable/bg_circle"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_me_user"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 右上角加号按钮 - 与三个气泡按钮横向对齐 -->
    <ImageView
        android:id="@+id/iv_add"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginEnd="-19dp"
        android:src="@drawable/ic_tab_add"
        android:tint="@android:color/white"
        app:layout_constraintEnd_toStartOf="@id/iv_avatar_top"
        app:layout_constraintTop_toTopOf="@id/nav_container"
        app:layout_constraintBottom_toBottomOf="@id/nav_container" />

    <!-- 顶部导航按钮区域 - ConstraintLayout -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/nav_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="25dp"
        android:layout_marginTop="100dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- 关注按钮（黑色底） -->
        <FrameLayout
            android:id="@+id/nav_follow"
            android:layout_width="70dp"
            android:layout_height="32dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_square_black" />
        </FrameLayout>

        <!-- 泡泡墙按钮（白底黑字） -->
        <FrameLayout
            android:id="@+id/nav_bubble"
            android:layout_width="70dp"
            android:layout_height="32dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_white_rounded"
            app:layout_constraintStart_toEndOf="@id/nav_follow"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:includeFontPadding="false"
                android:text="泡泡墙"
                android:textColor="#000000"
                android:textSize="14sp"
                android:fontFamily="@font/inter_bold" />
        </FrameLayout>

        <!-- 广播按钮（白底黑字） -->
        <FrameLayout
            android:id="@+id/nav_broadcast"
            android:layout_width="70dp"
            android:layout_height="32dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_white_rounded"
            app:layout_constraintStart_toEndOf="@id/nav_bubble"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:includeFontPadding="false"
                android:text="广播"
                android:textColor="#000000"
                android:textSize="14sp"
                android:fontFamily="@font/inter_bold" />
        </FrameLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 卡片列表 - RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_cards"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/nav_container" />

</androidx.constraintlayout.widget.ConstraintLayout>
