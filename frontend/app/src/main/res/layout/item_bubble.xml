<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- ic_bubble 容器图标 -->
    <ImageView
        android:id="@+id/ic_bubble"
        android:layout_width="53dp"
        android:layout_height="49dp"
        android:layout_marginStart="53dp"
        android:layout_marginTop="20dp"
        android:elevation="999dp"
        android:translationZ="999dp"
        android:src="@drawable/ic_bubble_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 星星容器（动态生成） -->
    <LinearLayout
        android:id="@+id/stars_container"
        android:layout_width="53dp"
        android:layout_height="49dp"
        android:elevation="9998dp"
        android:translationZ="9997dp"
        app:layout_constraintStart_toStartOf="@id/ic_bubble"
        app:layout_constraintTop_toTopOf="@id/ic_bubble" />

    <!-- tv_bubble 文字 -->
    <TextView
        android:id="@+id/tv_bubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="7dp"
        android:elevation="999dp"
        android:fontFamily="sans-serif-black"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        app:layout_constraintStart_toEndOf="@id/ic_bubble"
        app:layout_constraintTop_toTopOf="@id/ic_bubble" />

    <!-- tv_number 数字 -->
    <TextView
        android:id="@+id/tv_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="-63dp"
        android:elevation="999dp"
        android:fontFamily="@font/inter"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        app:layout_constraintStart_toEndOf="@id/tv_bubble"
        app:layout_constraintBottom_toBottomOf="@id/ic_bubble" />

    <!-- ic_chat_line 分隔线 -->
    <ImageView
        android:id="@+id/ic_chat_line"
        android:layout_width="300dp"
        android:layout_height="1dp"
        android:layout_marginStart="55dp"
        android:layout_marginTop="5dp"
        android:elevation="999dp"
        android:scaleType="fitXY"
        android:src="@drawable/ic_chat_line"
        android:translationZ="999dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ic_bubble" />

</androidx.constraintlayout.widget.ConstraintLayout>
