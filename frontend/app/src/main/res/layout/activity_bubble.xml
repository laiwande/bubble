<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 背景 -->
    <ImageView
        android:id="@+id/iv_bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="fitXY"
        android:src="@drawable/bg_bubble"
        android:elevation="0dp"
        app:layout_constraintBottom_toBottomOf="@id/bottom_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_title"
        android:layout_marginTop="-70dp" />

    <!-- 顶部标题占位 -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:layout_marginTop="110dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 顶部搜索栏 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/search_container"
        android:layout_width="380dp"
        android:layout_height="40dp"
        android:layout_marginTop="75dp"
        android:background="@drawable/bg_search_rounded"
        android:elevation="4dp"
        android:paddingStart="12dp"
        android:paddingTop="8dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_search_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_bubble_search"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/et_search"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:background="@android:color/transparent"
            android:fontFamily="@font/inter"
            android:gravity="center_vertical"
            android:hint="Search"
            android:textColor="#828282"
            android:textColorHint="#828282"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/iv_search_icon"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 望远镜装饰 - 右上角 -->

    <!-- 气泡容器 - 动态生成气泡（望远镜下方） -->
    <FrameLayout
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:elevation="3dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/search_container"
        android:layout_marginStart="40dp"
        android:layout_marginTop="60dp">
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_bubble_container"
            android:scaleType="fitXY" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="摄影"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:fontFamily="@font/sourcehanserifcn"
            android:alpha="0.9" />
    </FrameLayout>

    <FrameLayout
        android:layout_width="55dp"
        android:layout_height="55dp"
        android:elevation="3dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/search_container"
        android:layout_marginStart="150dp"
        android:layout_marginTop="40dp">
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_bubble_container"
            android:scaleType="fitXY" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="手账"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:fontFamily="@font/sourcehanserifcn"
            android:alpha="0.9" />
    </FrameLayout>

    <FrameLayout
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:elevation="3dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/search_container"
        android:layout_marginStart="240dp"
        android:layout_marginTop="85dp">
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_bubble_container"
            android:scaleType="fitXY" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="COS"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:fontFamily="@font/sourcehanserifcn"
            android:alpha="0.9" />
    </FrameLayout>

    <FrameLayout
        android:layout_width="65dp"
        android:layout_height="65dp"
        android:elevation="3dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/search_container"
        android:layout_marginStart="30dp"
        android:layout_marginTop="160dp">
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_bubble_container"
            android:scaleType="fitXY" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="游戏"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:fontFamily="@font/sourcehanserifcn"
            android:alpha="0.9" />
    </FrameLayout>

    <FrameLayout
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:elevation="3dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/search_container"
        android:layout_marginStart="130dp"
        android:layout_marginTop="130dp">
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_bubble_container"
            android:scaleType="fitXY" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="同人"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="@font/sourcehanserifcn"
            android:alpha="0.9" />
    </FrameLayout>

    <FrameLayout
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:elevation="3dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/search_container"
        android:layout_marginStart="260dp"
        android:layout_marginTop="180dp">
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_bubble_container"
            android:scaleType="fitXY" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="手绘"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:fontFamily="@font/sourcehanserifcn"
            android:alpha="0.9" />
    </FrameLayout>

    <FrameLayout
        android:layout_width="75dp"
        android:layout_height="75dp"
        android:elevation="3dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/search_container"
        android:layout_marginStart="50dp"
        android:layout_marginTop="260dp">
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_bubble_container"
            android:scaleType="fitXY" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="旅行"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:fontFamily="@font/sourcehanserifcn"
            android:alpha="0.9" />
    </FrameLayout>

    <FrameLayout
        android:layout_width="85dp"
        android:layout_height="85dp"
        android:elevation="3dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/search_container"
        android:layout_marginStart="170dp"
        android:layout_marginTop="250dp">
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_bubble_container"
            android:scaleType="fitXY" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="美食"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:fontFamily="@font/sourcehanserifcn"
            android:alpha="0.9" />
    </FrameLayout>

    <FrameLayout
        android:layout_width="55dp"
        android:layout_height="55dp"
        android:elevation="3dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/search_container"
        android:layout_marginStart="290dp"
        android:layout_marginTop="300dp">
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_bubble_container"
            android:scaleType="fitXY" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="二次元"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:fontFamily="@font/sourcehanserifcn"
            android:alpha="0.9" />
    </FrameLayout>

    <FrameLayout
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:elevation="3dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/search_container"
        android:layout_marginStart="80dp"
        android:layout_marginTop="370dp">
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_bubble_container"
            android:scaleType="fitXY" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="国风"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:fontFamily="@font/sourcehanserifcn"
            android:alpha="0.9" />
    </FrameLayout>

    <FrameLayout
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:elevation="3dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/search_container"
        android:layout_marginStart="200dp"
        android:layout_marginTop="380dp">
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_bubble_container"
            android:scaleType="fitXY" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="设计"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:fontFamily="@font/sourcehanserifcn"
            android:alpha="0.9" />
    </FrameLayout>

    <FrameLayout
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:elevation="3dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/search_container"
        android:layout_marginStart="280dp"
        android:layout_marginTop="420dp">
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_bubble_container"
            android:scaleType="fitXY" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="宠物"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:fontFamily="@font/sourcehanserifcn"
            android:alpha="0.9" />
    </FrameLayout>

    <!-- 底部导航栏 -->

    <FrameLayout
        android:id="@+id/bubble_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginBottom="68dp"
        android:elevation="2dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/search_container"
        app:layout_constraintVertical_bias="1.0" />

    <com.bubble.ui.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bottom_nav_rounded"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 望远镜装饰 - 最上层 -->
    <ImageView
        android:id="@+id/ic_telescope"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_marginTop="70dp"
        android:layout_marginEnd="-50dp"
        android:alpha="1.0"
        android:clickable="true"
        android:focusable="true"
        android:rotation="0"
        android:src="@drawable/ic_bubble_telescope"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

        <!-- 文字装饰 - 可见 -->
    <TextView
        android:id="@+id/iv_bubble_word"
        android:layout_width="560dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="325dp"
        android:alpha="0.08"
        android:fontFamily="@font/archivo_black"
        android:gravity="center"
        android:rotation="-30"
        android:singleLine="true"
        android:text="bubble"
        android:textColor="#000000"
        android:textSize="140sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
