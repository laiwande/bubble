<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <!-- 背景图片 - 位置与login一致 -->
    <ImageView
        android:id="@+id/iv_bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="-70dp"
        android:scaleType="fitXY"
        android:src="@drawable/bg_add"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_title" />

    <!-- 顶部标题区域 -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="110dp"
        android:fontFamily="@font/archivo_black"
        android:letterSpacing="0.1"
        android:text=""
        android:textColor="@android:color/white"
        android:textSize="36sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 渐变色背景顶部的商店图标 -->
    <ImageView
        android:id="@+id/iv_choose_shop"
        android:layout_width="20dp"
        android:layout_height="30dp"
        android:layout_marginTop="60dp"
        android:elevation="2dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_choose_shop"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 可滚动的卡片展示区域 -->
    <ScrollView
        android:elevation="10dp"
        android:id="@+id/scroll_cards"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        android:clipToPadding="false"
        android:clipChildren="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="-50dp"
        app:layout_constraintTop_toBottomOf="@id/tv_title">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="0dp"
            android:paddingBottom="16dp">

            <!-- 卡片1 - card_bubble11 -->
            <FrameLayout
                android:layout_width="443dp"
                android:layout_height="220dp"
                android:layout_marginTop="0dp"
                android:layout_marginBottom="0dp">

                <ImageView
                    android:id="@+id/iv_card_bubble11"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:elevation="0dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/card_bubble11" />

                <ImageView
                    android:id="@+id/iv_add_card_1"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_gravity="top|start"
                    android:layout_marginStart="40dp"
                    android:layout_marginTop="0dp"
                    android:elevation="6dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_add_card" />
            </FrameLayout>

            <!-- 卡片2 - card_bubble22 -->
            <FrameLayout
                android:layout_width="443dp"
                android:layout_height="220dp"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="0dp">

                <ImageView
                    android:id="@+id/iv_card_bubble22"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:elevation="4dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/card_bubble22" />

                <ImageView
                    android:id="@+id/iv_add_card_2"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="top|start"
                    android:layout_marginTop="7dp"
                    android:layout_marginStart="40dp"
                    android:elevation="6dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_add_card" />
            </FrameLayout>

            <!-- 卡片3 - card_bubble33 -->
            <FrameLayout
                android:layout_width="443dp"
                android:layout_height="220dp"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="0dp">

                <ImageView
                    android:id="@+id/iv_card_bubble33"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:elevation="4dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/card_bubble33" />

                <ImageView
                    android:id="@+id/iv_add_card_3"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="top|start"
                    android:layout_marginTop="0dp"
                    android:layout_marginStart="40dp"
                    android:elevation="6dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_add_card" />
            </FrameLayout>

            <!-- 卡片4 - card_bubble44 -->
            <FrameLayout
                android:layout_width="415dp"
                android:layout_height="206dp"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="0dp">

                <ImageView
                    android:id="@+id/iv_card_bubble44"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:elevation="4dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/card_bubble44" />

                <ImageView
                    android:id="@+id/iv_add_card_4"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="top|start"
                    android:layout_marginTop="0dp"
                    android:layout_marginStart="25dp"
                    android:elevation="6dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_add_card" />
            </FrameLayout>

            <!-- 卡片5 - card_bubble55 -->
            <FrameLayout
                android:layout_width="415dp"
                android:layout_height="206dp"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="0dp">

                <ImageView
                    android:id="@+id/iv_card_bubble55"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:elevation="4dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/card_bubble55" />

                <ImageView
                    android:id="@+id/iv_add_card_5"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="top|start"
                    android:layout_marginTop="0dp"
                    android:layout_marginStart="25dp"
                    android:elevation="6dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_add_card" />
            </FrameLayout>

        </LinearLayout>
    </ScrollView>

    <!-- 两个勾选组合并排 -->
    <LinearLayout
        android:id="@+id/ll_tags"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="80dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/scroll_cards"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
